<!-- ── PLAYGROUND ──────────────────────────────────────────────── -->
<!-- Live API tester — developers can try every endpoint here -->

<div class="playground-layout">

  <!-- Left: controls -->
  <div class="pg-controls">

    <div class="card mb-sm">
      <div class="card-label">Credentials</div>
      <input type="text"     id="pgApiKey" class="pg-input" placeholder="x-ano-api-key" />
      <input type="text"     id="pgUserId" class="pg-input mt-xs" placeholder="x-ano-user-id" />
    </div>

    <!-- Endpoint tabs -->
    <div class="pg-tabs">
      <button class="pg-tab active" data-tab="feed">POST /feed</button>
      <button class="pg-tab" data-tab="event">POST /event</button>
      <button class="pg-tab" data-tab="onboard">POST /onboard</button>
      <button class="pg-tab" data-tab="profile">GET /profile</button>
    </div>

    <!-- Feed tab -->
    <div class="pg-panel active" id="tab-feed">
      <div class="card-label mt-sm">Posts (JSON array)</div>
      <textarea id="feedPosts" class="pg-textarea" rows="12">[
  {
    "id": "p1",
    "title": "Army conducts anti-terror operation in border region",
    "body": "Military forces launched a combat operation near the border.",
    "timestamp": "2026-03-13T10:00:00Z",
    "platform": "news"
  },
  {
    "id": "p2",
    "title": "SpaceX launches 23 Starlink satellites",
    "body": "SpaceX deployed satellites in a successful rocket launch.",
    "timestamp": "2026-03-13T08:00:00Z",
    "platform": "tech"
  },
  {
    "id": "p3",
    "title": "Get one Big Mac for $4",
    "body": "McDonald's running a limited-time food deal.",
    "timestamp": "2026-03-13T09:00:00Z",
    "platform": "social"
  }
]</textarea>
      <button class="btn btn-primary mt-sm full-w" onclick="runFeed()">Run →</button>
    </div>

    <!-- Event tab -->
    <div class="pg-panel" id="tab-event">
      <div class="card-label mt-sm">Event type</div>
      <select id="eventType" class="pg-input">
        <option>share</option><option>like</option><option>click</option>
        <option>view</option><option>skip</option><option>hide</option>
      </select>
      <div class="card-label mt-sm">Post (JSON)</div>
      <textarea id="eventPost" class="pg-textarea" rows="6">{
  "id": "p1",
  "title": "Army conducts anti-terror operation in border region",
  "body": "Military forces launched a combat operation near the border."
}</textarea>
      <button class="btn btn-primary mt-sm full-w" onclick="runEvent()">Send event →</button>
    </div>

    <!-- Onboard tab -->
    <div class="pg-panel" id="tab-onboard">
      <div class="card-label mt-sm">Topics to like</div>
      <div class="topic-picker" id="likePicker">
        <% ['military','aviation','politics','economy','technology','health','sports','food','science','entertainment','crime','business'].forEach(t => { %>
          <label class="topic-toggle"><input type="checkbox" value="<%= t %>" /><%= t %></label>
        <% }) %>
      </div>
      <div class="card-label mt-sm">Topics to dislike</div>
      <div class="topic-picker" id="dislikePicker">
        <% ['military','aviation','politics','economy','technology','health','sports','food','science','entertainment','crime','business'].forEach(t => { %>
          <label class="topic-toggle dislike"><input type="checkbox" value="<%= t %>" /><%= t %></label>
        <% }) %>
      </div>
      <button class="btn btn-primary mt-sm full-w" onclick="runOnboard()">Onboard user →</button>
    </div>

    <!-- Profile tab -->
    <div class="pg-panel" id="tab-profile">
      <p class="muted mt-sm">Fetches the profile for the user ID entered above.</p>
      <button class="btn btn-primary mt-sm full-w" onclick="runProfile()">Fetch profile →</button>
    </div>

  </div>

  <!-- Right: response -->
  <div class="pg-response">
    <div class="pg-response-header">
      <span class="card-label">Response</span>
      <span id="pgStatus" class="status-badge"></span>
    </div>
    <pre id="pgOutput" class="code-body pg-output">// Run a request to see the response here</pre>
  </div>

</div>

<!-- Tab switching + API calls -->
<script>
// Tab switching
document.querySelectorAll('.pg-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.pg-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.pg-panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
  });
});

function headers() {
  return {
    'Content-Type'  : 'application/json',
    'x-ano-api-key' : document.getElementById('pgApiKey').value,
    'x-ano-user-id' : document.getElementById('pgUserId').value,
  };
}

function showResponse(res, data) {
  const badge = document.getElementById('pgStatus');
  badge.textContent = res.status + ' ' + (res.ok ? 'OK' : 'Error');
  badge.className = 'status-badge ' + (res.ok ? 'ok' : 'err');
  document.getElementById('pgOutput').textContent = JSON.stringify(data, null, 2);
}

async function runFeed() {
  const posts = JSON.parse(document.getElementById('feedPosts').value);
  const res   = await fetch('/feed', { method: 'POST', headers: headers(), body: JSON.stringify({ posts }) });
  showResponse(res, await res.json());
}

async function runEvent() {
  const post = JSON.parse(document.getElementById('eventPost').value);
  const eventType = document.getElementById('eventType').value;
  const res = await fetch('/event', { method: 'POST', headers: headers(), body: JSON.stringify({ eventType, post }) });
  showResponse(res, await res.json());
}

async function runOnboard() {
  const like    = [...document.querySelectorAll('#likePicker input:checked')].map(i => i.value);
  const dislike = [...document.querySelectorAll('#dislikePicker input:checked')].map(i => i.value);
  const userId  = document.getElementById('pgUserId').value;
  const res = await fetch('/profile/' + userId + '/onboard', {
    method : 'POST',
    headers: { 'Content-Type': 'application/json', 'x-ano-api-key': document.getElementById('pgApiKey').value },
    body   : JSON.stringify({ like, dislike }),
  });
  showResponse(res, await res.json());
}

async function runProfile() {
  const userId = document.getElementById('pgUserId').value;
  const res = await fetch('/profile/' + userId, {
    headers: { 'x-ano-api-key': document.getElementById('pgApiKey').value },
  });
  showResponse(res, await res.json());
}
</script>
