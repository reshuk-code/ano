<!-- ── HERO ─────────────────────────────────────────────────── -->
<section class="lp-hero">
  <div class="lp-hero-glow"></div>
  <div class="lp-hero-inner">
    <div class="lp-hero-eyebrow">
      <span class="lp-eyebrow-dot"></span>
      Feed personalization · API-first · No ML required
    </div>
    <h1 class="lp-hero-h1">
      Add personalized feeds<br/>
      to your app<br/>
      <span class="lp-h1-accent">in one afternoon.</span>
    </h1>
    <p class="lp-hero-sub">
      ano is a REST API that ranks your content by what each user actually cares about.
      You send posts, we return them ranked. The feed improves with every interaction.
    </p>
    <div class="lp-hero-cta">
      <% if (user) { %>
        <a href="/dashboard" class="btn btn-primary btn-lg">Go to Dashboard →</a>
      <% } else { %>
        <a href="/login" class="btn btn-primary btn-lg">Get your API key — it's free</a>
      <% } %>
      <a href="#demo" class="btn btn-ghost btn-lg">See the demo</a>
    </div>
    <div class="lp-hero-proof">
      <span class="lp-proof-item"><span class="lp-proof-dot"></span>No training data needed</span>
      <span class="lp-proof-sep">·</span>
      <span class="lp-proof-item"><span class="lp-proof-dot"></span>Works from day one</span>
      <span class="lp-proof-sep">·</span>
      <span class="lp-proof-item"><span class="lp-proof-dot"></span>Any content type</span>
    </div>
  </div>

  <!-- Hero code block -->
  <div class="lp-hero-code">
    <div class="code-window">
      <div class="code-topbar">
        <span class="code-dot red"></span>
        <span class="code-dot yellow"></span>
        <span class="code-dot green"></span>
        <span class="code-filename">integrate.js</span>
        <span class="lp-code-lines">12 lines</span>
      </div>
      <pre class="code-body"><span class="tok-comment">// 1. Onboard a new user (once)</span>
<span class="tok-keyword">await</span> fetch(<span class="tok-string">"/profile/user_123/onboard"</span>, {
  method : <span class="tok-string">"POST"</span>,
  headers: { <span class="tok-string">"x-ano-api-key"</span>: key },
  body   : JSON.stringify({ like: [<span class="tok-string">"tech"</span>, <span class="tok-string">"science"</span>] })
});

<span class="tok-comment">// 2. Get a ranked feed (every page load)</span>
<span class="tok-keyword">const</span> { feed } = <span class="tok-keyword">await</span> fetch(<span class="tok-string">"/feed"</span>, {
  method : <span class="tok-string">"POST"</span>,
  headers: { <span class="tok-string">"x-ano-api-key"</span>: key, <span class="tok-string">"x-ano-user-id"</span>: userId },
  body   : JSON.stringify({ posts: yourPosts })
}).then(r => r.json());
<span class="tok-comment">// feed[0] = most relevant post for this user ✓</span></pre>
    </div>
  </div>
</section>

<!-- ── STATS BAR ───────────────────────────────────────────── -->
<div class="lp-stats">
  <div class="lp-stat"><div class="lp-stat-n">6</div><div class="lp-stat-l">Engagement signals</div></div>
  <div class="lp-stat-sep"></div>
  <div class="lp-stat"><div class="lp-stat-n">12</div><div class="lp-stat-l">Topic categories</div></div>
  <div class="lp-stat-sep"></div>
  <div class="lp-stat"><div class="lp-stat-n">24h</div><div class="lp-stat-l">Recency half-life</div></div>
  <div class="lp-stat-sep"></div>
  <div class="lp-stat"><div class="lp-stat-n">0ms</div><div class="lp-stat-l">Training time needed</div></div>
</div>

<!-- ── PROBLEM / SOLUTION ─────────────────────────────────── -->
<section class="lp-section lp-compare" id="problem">
  <div class="lp-section-label">The problem</div>
  <div class="lp-compare-grid">
    <div class="lp-compare-card lp-bad">
      <div class="lp-compare-icon lp-bad-icon">✗</div>
      <h3>Without ano</h3>
      <ul>
        <li>Every user sees the identical feed</li>
        <li>Zero signal from user behaviour</li>
        <li>Building a ranker takes months of engineering</li>
        <li>Needs massive data to train ML models</li>
      </ul>
    </div>
    <div class="lp-compare-divider">vs</div>
    <div class="lp-compare-card lp-good">
      <div class="lp-compare-icon lp-good-icon">✓</div>
      <h3>With ano</h3>
      <ul>
        <li>Every user gets a feed ranked for them</li>
        <li>Learns from likes, shares, skips automatically</li>
        <li>One afternoon to integrate, not months</li>
        <li>No model training — relevance from day one</li>
      </ul>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ───────────────────────────────────────── -->
<section class="lp-section" id="how-it-works">
  <div class="lp-section-label">How it works</div>
  <h2 class="lp-section-h2">Three API calls to integrate.</h2>
  <div class="lp-steps">
    <div class="lp-step">
      <div class="lp-step-num">01</div>
      <div class="lp-step-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      </div>
      <h3>You send posts</h3>
      <p>Pass any array of content — title, body, timestamp. ano extracts topic signals automatically using NLP. Zero configuration.</p>
      <div class="lp-step-endpoint"><span class="endpoint-badge post">POST</span>/feed</div>
    </div>
    <div class="lp-step-arrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </div>
    <div class="lp-step">
      <div class="lp-step-num">02</div>
      <div class="lp-step-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </div>
      <h3>ano profiles the user</h3>
      <p>Each user gets a preference profile that learns from explicit choices and implicit signals — likes, shares, skips, views.</p>
      <div class="lp-step-endpoint"><span class="endpoint-badge post">POST</span>/event</div>
    </div>
    <div class="lp-step-arrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </div>
    <div class="lp-step">
      <div class="lp-step-num">03</div>
      <div class="lp-step-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <h3>You get a ranked feed</h3>
      <p>Posts come back sorted by relevance with a full score breakdown. Show users <em>exactly why</em> they're seeing each post.</p>
      <div class="lp-step-endpoint"><span class="endpoint-badge get">GET</span>/profile/:id</div>
    </div>
  </div>
</section>

<!-- ── TOPICS ─────────────────────────────────────────────── -->
<section class="lp-section lp-topics-section">
  <div class="lp-section-label">Built-in topic intelligence</div>
  <h2 class="lp-section-h2">12 content domains, built in.</h2>
  <p class="lp-section-p">ano understands topic signals automatically. No training data, no labelling, no configuration required.</p>
  <div class="lp-topic-chips">
    <% [
      {t:'military',icon:'⚔️'},{t:'aviation',icon:'✈️'},{t:'politics',icon:'🏛️'},
      {t:'economy',icon:'📈'},{t:'technology',icon:'💻'},{t:'health',icon:'🏥'},
      {t:'sports',icon:'⚽'},{t:'food',icon:'🍜'},{t:'science',icon:'🔬'},
      {t:'entertainment',icon:'🎬'},{t:'crime',icon:'🔍'},{t:'business',icon:'💼'}
    ].forEach(({t,icon}) => { %>
      <div class="lp-topic-chip"><span><%= icon %></span><%= t %></div>
    <% }) %>
  </div>
</section>

<!-- ── LIVE DEMO ──────────────────────────────────────────── -->
<section class="lp-section lp-demo-section" id="demo">
  <div class="lp-section-label">Live demo</div>
  <h2 class="lp-section-h2">Try it yourself.</h2>
  <p class="lp-section-p">Select your interests, hit rank, and see how the API orders these posts for your preference profile. This is calling the real ano API.</p>

  <div class="demo-shell">
    <div class="demo-controls">
      <div class="demo-block">
        <div class="demo-block-label">1 · Your interests <span style="color:var(--text-3);font-weight:400">(click = like · right-click = dislike)</span></div>
        <div class="demo-topic-grid" id="demoTopics"></div>
      </div>
      <div class="demo-block">
        <div class="demo-block-label">2 · User handle</div>
        <div class="demo-uid-row">
          <span class="demo-uid-at">@</span>
          <input id="demoUid" type="text" value="demo_visitor" placeholder="your_handle" class="demo-uid-input" />
        </div>
      </div>
      <button id="demoRunBtn" class="btn btn-primary" style="width:100%;justify-content:center">↻ Rank my feed</button>
      <div id="demoStatus" class="demo-status hidden"></div>
    </div>
    <div class="demo-output">
      <div class="demo-output-header">
        <span class="demo-output-title">Ranked Feed</span>
        <span id="demoCount" class="demo-output-count"></span>
      </div>
      <div id="demoFeed" class="demo-feed">
        <div class="demo-empty">← Pick topics and hit rank to see the algorithm live</div>
      </div>
    </div>
  </div>
</section>

