<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ano — Sign in</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body class="auth-body">

  <div class="auth-split">

    <!-- Left: branding -->
    <div class="auth-brand">
      <a href="/" class="auth-logo">
        <div class="logo-mark">a</div>
        <span class="logo-text">ano</span>
      </a>
      <div class="auth-brand-body">
        <h1 class="auth-brand-headline">The feed algorithm<br/>your users deserve.</h1>
        <p class="auth-brand-sub">Sign in to get your API key and start building personalized feeds in minutes.</p>
        <div class="auth-features">
          <div class="auth-feature">
            <span class="auth-feature-dot"></span>
            Drop-in REST API — no ML setup
          </div>
          <div class="auth-feature">
            <span class="auth-feature-dot"></span>
            Learns from every user interaction
          </div>
          <div class="auth-feature">
            <span class="auth-feature-dot"></span>
            Full explainability per ranked post
          </div>
          <div class="auth-feature">
            <span class="auth-feature-dot"></span>
            Multi-tenant — your users, your data
          </div>
        </div>
      </div>
    </div>

    <!-- Right: auth form -->
    <div class="auth-panel">
      <div class="auth-card">
        <div class="auth-card-header">
          <h2 class="auth-card-title">Sign in to ano</h2>
          <p class="auth-card-sub">New? Your account is created automatically.</p>
        </div>

        <!-- Error banner -->
        <div id="authError" class="auth-error hidden"></div>

        <!-- OAuth buttons -->
        <div class="auth-oauth">
          <button class="oauth-btn" id="googleBtn" onclick="signInGoogle()">
            <svg viewBox="0 0 24 24" width="18" height="18">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>

          <button class="oauth-btn" id="githubBtn" onclick="signInGithub()">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Continue with GitHub
          </button>
        </div>

        <!-- Divider -->
        <div class="auth-divider">
          <span>or sign in with email</span>
        </div>

        <!-- Email/password form -->
        <form id="emailForm" class="auth-form" onsubmit="return false">
          <div class="auth-field">
            <label>Email</label>
            <input type="email" id="authEmail" placeholder="you@company.com" autocomplete="email"/>
          </div>
          <div class="auth-field">
            <label>Password</label>
            <input type="password" id="authPassword" placeholder="••••••••" autocomplete="current-password"/>
          </div>
          <div class="auth-form-actions">
            <button class="btn btn-primary full-w" id="emailSignInBtn" onclick="signInEmail()">Sign in</button>
            <button class="btn btn-ghost full-w" id="emailSignUpBtn" onclick="signUpEmail()">Create account</button>
          </div>
          <div class="auth-forgot">
            <a href="#" onclick="resetPassword()">Forgot password?</a>
          </div>
        </form>

        <p class="auth-terms">
          By signing in you agree to ano's terms of service.
        </p>
      </div>
    </div>

  </div>

  <!-- Firebase SDK (client-side only) -->
  <script type="module">
    import { initializeApp }                    from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
    import { getAuth, GoogleAuthProvider, GithubAuthProvider,
             signInWithPopup, signInWithEmailAndPassword,
             createUserWithEmailAndPassword, sendPasswordResetEmail }
      from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";

    const firebaseConfig = <%- JSON.stringify(firebaseConfig) %>;
    const fbApp  = initializeApp(firebaseConfig);
    const auth   = getAuth(fbApp);

    // ── After any successful sign-in ──────────────────────────
    async function handleSignIn(userCredential) {
      const user    = userCredential.user;
      const idToken = await user.getIdToken();

      const res = await fetch("/auth/session", {
        method : "POST",
        headers: { "Content-Type": "application/json" },
        body   : JSON.stringify({
          idToken,
          user: {
            uid        : user.uid,
            email      : user.email,
            displayName: user.displayName || "",
            photoURL   : user.photoURL    || "",
          },
        }),
      });

      if (res.ok) {
        window.location.href = "/dashboard";
      } else {
        const d = await res.json();
        showError(d.error || "Sign-in failed. Please try again.");
      }
    }

    function showError(msg) {
      const el = document.getElementById("authError");
      el.textContent = msg;
      el.classList.remove("hidden");
    }

    function setLoading(id, loading) {
      const btn = document.getElementById(id);
      btn.disabled = loading;
      if (loading) btn.dataset.orig = btn.textContent;
      btn.textContent = loading ? "Signing in…" : btn.dataset.orig;
    }

    // Google
    window.signInGoogle = async () => {
      setLoading("googleBtn", true);
      try {
        await handleSignIn(await signInWithPopup(auth, new GoogleAuthProvider()));
      } catch (e) {
        showError(e.code === "auth/popup-closed-by-user" ? "Sign-in cancelled." : e.message);
        setLoading("googleBtn", false);
      }
    };

    // GitHub
    window.signInGithub = async () => {
      setLoading("githubBtn", true);
      try {
        await handleSignIn(await signInWithPopup(auth, new GithubAuthProvider()));
      } catch (e) {
        showError(e.code === "auth/popup-closed-by-user" ? "Sign-in cancelled." : e.message);
        setLoading("githubBtn", false);
      }
    };

    // Email sign in
    window.signInEmail = async () => {
      const email    = document.getElementById("authEmail").value.trim();
      const password = document.getElementById("authPassword").value;
      if (!email || !password) return showError("Enter your email and password.");
      setLoading("emailSignInBtn", true);
      try {
        await handleSignIn(await signInWithEmailAndPassword(auth, email, password));
      } catch (e) {
        showError(e.code === "auth/wrong-password" || e.code === "auth/user-not-found"
          ? "Incorrect email or password." : e.message);
        setLoading("emailSignInBtn", false);
      }
    };

    // Email sign up
    window.signUpEmail = async () => {
      const email    = document.getElementById("authEmail").value.trim();
      const password = document.getElementById("authPassword").value;
      if (!email || !password) return showError("Enter your email and a password (min 6 chars).");
      if (password.length < 6) return showError("Password must be at least 6 characters.");
      setLoading("emailSignUpBtn", true);
      try {
        await handleSignIn(await createUserWithEmailAndPassword(auth, email, password));
      } catch (e) {
        showError(e.code === "auth/email-already-in-use"
          ? "That email is already registered. Try signing in instead." : e.message);
        setLoading("emailSignUpBtn", false);
      }
    };

    // Password reset
    window.resetPassword = async () => {
      const email = document.getElementById("authEmail").value.trim();
      if (!email) return showError("Enter your email address first.");
      try {
        await sendPasswordResetEmail(auth, email);
        showError("Reset email sent — check your inbox.");
        document.getElementById("authError").style.borderColor = "var(--accent)";
        document.getElementById("authError").style.color = "var(--accent)";
      } catch (e) {
        showError(e.message);
      }
    };
  </script>
</body>
</html>
